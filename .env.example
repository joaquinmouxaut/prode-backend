DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prode2026?schema=public"
PORT=3000
# Required for JWT signing/verification (set a long random value in real envs).
# Backend bootstrap fails fast when this env var is missing.
JWT_SECRET="change-this-to-a-long-random-secret"
# Comma-separated browser origins allowed to call the API (Angular dev server by default).
CORS_ORIGIN="http://localhost:4200"
FOOTBALL_DATA_API_TOKEN=""
FOOTBALL_DATA_BASE_URL="https://api.football-data.org/v4"
FOOTBALL_DATA_COMPETITION_CODE="WC"
FOOTBALL_DATA_SEASON=2026
FIXTURE_POLL_ENABLED=true
FIXTURE_POLL_MINUTES=15
FIXTURE_POLL_TICKER_SECONDS=60
FOOTBALL_API_MAX_REQUESTS_PER_DAY=80
