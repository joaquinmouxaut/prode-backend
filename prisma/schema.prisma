// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Phase {
  GROUPS_1
  GROUPS_2
  GROUPS_3
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum Role {
  USER
  ADMIN
}

enum MatchResultSource {
  ADMIN
  API
  IMPORT
}

/** Lado del partido (local/visitante). Usado para registrar quién avanza en mata-mata. */
enum TeamSide {
  HOME
  AWAY
}

/** Cómo se definió un partido de eliminatoria. */
enum MatchDecision {
  REGULAR
  EXTRA_TIME
  PENALTIES
}

model User {
  id            Int          @id @default(autoincrement())
  name          String
  email         String       @unique
  passwordHash  String
  role          Role         @default(USER)
  championPick  String?
  topScorerPick String?
  championPoints Int          @default(0)
  topScorerPoints Int         @default(0)
  totalPoints   Int          @default(0)
  groups1       Int          @default(0)
  groups2       Int          @default(0)
  groups3       Int          @default(0)
  knockout      Int          @default(0)
  predictions   Prediction[]
}

model Match {
  id            Int               @id @default(autoincrement())
  externalId    String?           @unique
  homeTeam      String
  awayTeam      String
  homeGoals     Int?
  awayGoals     Int?
  date          DateTime
  phase         Phase
  groupCode     String?
  externalStatus String?
  resultSource  MatchResultSource?
  manualOverride Boolean          @default(false)
  lastSyncedAt  DateTime?
  finalizedAt   DateTime?
  winnerSide    TeamSide?
  decidedBy     MatchDecision?
  predictions   Prediction[]
}

model Prediction {
  id            Int       @id @default(autoincrement())
  userId        Int
  matchId       Int
  homeGoals     Int
  awayGoals     Int
  advancingTeam TeamSide?
  points        Int       @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model TournamentConfig {
  id              Int     @id @default(1)
  championTeam    String?
  topScorerPlayer String?
}
